            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/sasha/ontologies/2026/1/untitled-ontology-14#Персонал"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/sasha/ontologies/2026/1/untitled-ontology-14#должность"/>
                        <owl:hasValue>Эндокринолог</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


