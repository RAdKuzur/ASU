    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/sasha/ontologies/2026/1/untitled-ontology-14#Администратор -->

    <owl:Class rdf:about="http://www.semanticweb.org/sasha/ontologies/2026/1/untitled-ontology-14#Администратор">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/sasha/ontologies/2026/1/untitled-ontology-14#Персонал"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/sasha/ontologies/2026/1/untitled-ontology-14#должность"/>
                        <owl:hasValue>Администратор</owl:hasValue>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/sasha/ontologies/2026/1/untitled-ontology-14#есть_права_администратора"/>
                        <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sasha/ontologies/2026/1/untitled-ontology-14#Персонал"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sasha/ontologies/2026/1/untitled-ontology-14#Весы -->

    <owl:Class rdf:about="http://www.semanticweb.org/sasha/ontologies/2026/1/untitled-ontology-14#Весы">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sasha/ontologies/2026/1/untitled-ontology-14#Медицинское_устройство"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sasha/ontologies/2026/1/untitled-ontology-14#Взрослый_пациент -->

    <owl:Class rdf:about="http://www.semanticweb.org/sasha/ontologies/2026/1/untitled-ontology-14#Взрослый_пациент">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/sasha/ontologies/2026/1/untitled-ontology-14#Пациент"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/sasha/ontologies/2026/1/untitled-ontology-14#возраст"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">18</xsd:minInclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sasha/ontologies/2026/1/untitled-ontology-14#Пациент"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/sasha/ontologies/2026/1/untitled-ontology-14#Несовершеннолетний_пациент"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sasha/ontologies/2026/1/untitled-ontology-14#Внешние_пользователи -->

    <owl:Class rdf:about="http://www.semanticweb.org/sasha/ontologies/2026/1/untitled-ontology-14#Внешние_пользователи">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sasha/ontologies/2026/1/untitled-ontology-14#Пользователи"/>
